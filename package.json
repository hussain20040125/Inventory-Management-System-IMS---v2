{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "rm -rf dist && vite build frontend --outDir ../dist/public && esbuild server.ts --bundle --platform=node --target=node22 --outfile=dist/server.cjs --external:express --external:mongoose --external:cloudinary --external:dotenv --external:cookie-parser --external:cors --external:jsonwebtoken --external:bcryptjs --external:multer --external:multer-storage-cloudinary --external:ws --external:xlsx --external:vite --external:fs --external:path --external:http",
    "start": "node dist/server.cjs",
    "preview": "vite preview frontend",
    "clean": "rm -rf frontend/dist",
    "lint": "tsc --noEmit -p frontend/tsconfig.json"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "cloudinary": "^1.41.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.3.3",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
